{
  "manifest_version": 3,
  "name": "DOM Interaction Recorder",
  "version": "1.0.0",
  "description": "Records user interactions with websites for test automation and documentation",
  
  "permissions": [
    "storage",
    "downloads",
    "scripting",
    "tabs",
    "activeTab"
  ],
  
  "host_permissions": [
    "<all_urls>"
  ],
  
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/tracker.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  
  "action": {
    "default_popup": "ui/popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "DOM Interaction Recorder"
  },
  
  "side_panel": {
    "default_path": "ui/sidepanel/sidepanel.html"
  },
  
  "options_page": "ui/options/options.html",
  
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  
  "web_accessible_resources": [
    {
      "resources": ["ui/annotation/annotation.css"],
      "matches": ["<all_urls>"]
    }
  ]
}
